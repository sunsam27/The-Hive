{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import dotenv/config dist/index.js",
    "build": "tsc",
    "migrate": "tsx --import dotenv/config -e \"import db from './src/db/index.ts'; db.migrate.latest().then(() => { console.log('Migrations complete'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); });\"",
    "seed": "tsx --import dotenv/config -e \"import db from './src/db/index.ts'; db.seed.run().then(() => { console.log('Seeds complete'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); });\"",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^2.1.1",
    "pg": "^8.12.0",
    "resend": "^6.12.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "globals": "^17.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
