PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/the_hive

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# Frontend URL (used for CORS + email links)
# In production: set to your Vercel deployment URL
FRONTEND_URL=http://localhost:5173

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx

# OCR.space (receipt scanning)
# Get a free API key at https://ocr.space/ocrapi
OCR_SPACE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (file storage)
# Get credentials at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Flutterwave (payment processing)
# Get credentials at https://dashboard.flutterwave.com
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_SECRET_HASH=your-flutterwave-webhook-secret-hash
